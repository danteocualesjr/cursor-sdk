# Cursor SDK is preferred when available.
CURSOR_API_KEY=
CURSOR_MODEL=composer-2

# OpenAI is used as a fallback when CURSOR_API_KEY is not set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Maximum time (ms) to wait for an AI provider before falling back.
# Defaults to 30000 (30s). Lower this in dev for faster fallback feedback.
AGENT_TIMEOUT_MS=30000

# Public origin used for sitemap.xml, robots.txt, and OpenGraph URLs.
# In Vercel deployments VERCEL_URL is used as a fallback automatically.
NEXT_PUBLIC_SITE_URL=
